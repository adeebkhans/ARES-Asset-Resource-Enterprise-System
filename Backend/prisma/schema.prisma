// ARES (AssetFlow) — Prisma schema
// Phase 0 scope: tenancy/identity, master data, assets & lifecycle.
// Later phases extend this file with allocations, bookings, maintenance,
// audits, the generic approval engine, and the custom-object framework.
// See plan.md Section 4 for the full target data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// 4.1 Tenancy & Identity
// ---------------------------------------------------------------------------

enum IndustryTag {
  GENERIC
  SCHOOL
  HOSPITAL
  HOTEL
  FACTORY
  OTHER
}

model Organization {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  industryTag IndustryTag @default(GENERIC)
  settings    Json        @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users              User[]
  departments        Department[]
  assetCategories    AssetCategory[]
  assets             Asset[]
  maintenanceRequests MaintenanceRequest[]
  auditCycles        AuditCycle[]
  approvalRules      ApprovalRule[]
  approvals          Approval[]
  approvalDelegations ApprovalDelegation[]

  @@map("organizations")
}

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String     @id @default(uuid())
  orgId        String
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(EMPLOYEE)
  departmentId String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  organization       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department         Department?        @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  refreshTokens      RefreshToken[]
  headOfDepartments  Department[]       @relation("DepartmentHead")
  maintenanceRequests MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  auditAssignments   AuditAssignment[]
  auditRecords       AuditRecord[]      @relation("AuditRecordsAuditedBy")
  auditCyclesCreated AuditCycle[]       @relation("AuditCycleCreator")
  approvalsRequested Approval[]         @relation("ApprovalRequestedBy")
  approvalsCurrent   Approval[]         @relation("ApprovalCurrentApprover")
  approvalsDecided   Approval[]         @relation("ApprovalDecidedBy")
  delegationsGiven   ApprovalDelegation[] @relation("ApprovalDelegationDelegator")
  delegationsReceived ApprovalDelegation[] @relation("ApprovalDelegationDelegate")

  @@unique([orgId, email])
  @@index([orgId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// 4.2 Master Data
// ---------------------------------------------------------------------------

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model Department {
  id                 String           @id @default(uuid())
  orgId              String
  name               String
  headUserId         String?
  parentDepartmentId String?
  status             DepartmentStatus @default(ACTIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  head         User?             @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: SetNull)
  parent       Department?       @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  children     Department[]      @relation("DepartmentHierarchy")
  members      User[]            @relation("DepartmentMembers")
  auditCycles  AuditCycle[]      @relation("AuditCycleScope")

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

model AssetCategory {
  id                String   @id @default(uuid())
  orgId             String
  name              String
  description       String?
  customFieldSchema Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assets       Asset[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("asset_categories")
}

// ---------------------------------------------------------------------------
// 4.3 Assets & Lifecycle
// ---------------------------------------------------------------------------

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

model Asset {
  id                String      @id @default(uuid())
  orgId             String
  assetTag          String
  name              String
  categoryId        String
  serialNumber      String?
  acquisitionDate   DateTime?
  acquisitionCost   Decimal?    @db.Decimal(12, 2)
  condition         String?
  location          String?
  isShared          Boolean     @default(false)
  status            AssetStatus @default(AVAILABLE)
  customFieldValues Json        @default("{}")
  qrCodeUrl         String?
  photos            String[]    @default([])
  documents         String[]    @default([])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  organization  Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category      AssetCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  statusHistory AssetStatusHistory[]
  maintenanceRequests MaintenanceRequest[]
  auditRecords        AuditRecord[]

  @@unique([orgId, assetTag])
  @@index([orgId])
  @@index([orgId, status])
  @@map("assets")
}

enum AssetStatusChangeSource {
  MANUAL
  ALLOCATION
  MAINTENANCE
  AUDIT
  TRANSFER
}

model AssetStatusHistory {
  id         String                  @id @default(uuid())
  assetId    String
  fromStatus AssetStatus?
  toStatus   AssetStatus
  changedBy  String?
  reason     String?
  source     AssetStatusChangeSource @default(MANUAL)
  timestamp  DateTime                @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_status_history")
}

// ---------------------------------------------------------------------------
// 4.5 Maintenance
// ---------------------------------------------------------------------------

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model MaintenanceRequest {
  id               String            @id @default(uuid())
  orgId            String
  assetId          String
  raisedById       String
  issueDescription String
  priority         MaintenancePriority @default(MEDIUM)
  photos           String[]          @default([])
  technicianName   String?
  status           MaintenanceStatus @default(PENDING)
  resolvedAt       DateTime?
  resolutionNotes  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  raisedBy     User               @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([orgId, status])
  @@index([assetId])
  @@map("maintenance_requests")
}

// ---------------------------------------------------------------------------
// 4.6 Audits
// ---------------------------------------------------------------------------

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
}

model AuditCycle {
  id                 String          @id @default(uuid())
  orgId              String
  scopeDepartmentId  String?
  scopeLocation      String?
  startDate          DateTime
  endDate            DateTime
  status             AuditCycleStatus @default(PLANNED)
  createdBy          String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scopeDepartment Department?         @relation("AuditCycleScope", fields: [scopeDepartmentId], references: [id], onDelete: SetNull)
  creator         User                @relation("AuditCycleCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  assignments     AuditAssignment[]
  records         AuditRecord[]
  discrepancyReport DiscrepancyReport?

  @@index([orgId])
  @@index([orgId, status])
  @@map("audit_cycles")
}

model AuditAssignment {
  id            String    @id @default(uuid())
  auditCycleId  String
  auditorUserId String
  createdAt     DateTime  @default(now())

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditor    User       @relation(fields: [auditorUserId], references: [id], onDelete: Cascade)

  @@unique([auditCycleId, auditorUserId])
  @@index([auditorUserId])
  @@map("audit_assignments")
}

enum AuditResult {
  VERIFIED
  MISSING
  DAMAGED
}

model AuditRecord {
  id            String      @id @default(uuid())
  auditCycleId  String
  assetId       String
  result        AuditResult
  notes         String?
  auditedById   String
  auditedAt     DateTime    @default(now())

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  auditedBy  User       @relation("AuditRecordsAuditedBy", fields: [auditedById], references: [id], onDelete: Restrict)

  @@unique([auditCycleId, assetId])
  @@index([assetId])
  @@map("audit_records")
}

model DiscrepancyReport {
  id           String   @id @default(uuid())
  auditCycleId String   @unique
  generatedAt  DateTime @default(now())
  itemCount    Int
  summary      Json

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)

  @@map("discrepancy_reports")
}

// ---------------------------------------------------------------------------
// 4.8 Notifications
// ---------------------------------------------------------------------------

model Notification {
  id                 String   @id @default(uuid())
  orgId              String
  userId             String
  type               String
  title              String
  message            String
  relatedEntityType  String?
  relatedEntityId    String?
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([orgId])
  @@index([orgId, userId])
  @@index([orgId, userId, isRead])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// 4.8 Activity Logs (Phase 1)
// ---------------------------------------------------------------------------

model ActivityLog {
  id           String   @id @default(uuid())
  orgId        String
  userId       String
  action       String
  entityType   String
  entityId     String
  metadata     Json     @default("{}")
  timestamp    DateTime @default(now())

  @@index([orgId])
  @@index([orgId, userId])
  @@index([orgId, entityType, entityId])
  @@map("activity_logs")
}

// ---------------------------------------------------------------------------
// 4.7 Generic Approval Engine (Phase 4)
// ---------------------------------------------------------------------------

enum ApprovalType {
  MAINTENANCE
  TRANSFER
  AUDIT_DISCREPANCY
  CUSTOM
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model ApprovalRule {
  id              String       @id @default(uuid())
  orgId           String
  approvalType    ApprovalType
  slaHours        Int          @default(24)
  escalateToRole  UserRole     @default(ADMIN)
  createdBy       String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, approvalType])
  @@index([orgId])
  @@map("approval_rules")
}

model Approval {
  id                    String         @id @default(uuid())
  orgId                 String
  type                  ApprovalType
  entityType            String
  entityId              String
  requestedById         String
  currentApproverUserId String?
  status                ApprovalStatus @default(PENDING)
  dueAt                 DateTime
  escalatedAt           DateTime?
  decidedById           String?
  decidedAt             DateTime?
  comment               String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requestedBy      User             @relation("ApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  currentApprover  User?            @relation("ApprovalCurrentApprover", fields: [currentApproverUserId], references: [id], onDelete: SetNull)
  decidedBy        User?            @relation("ApprovalDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([entityType, entityId])
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, currentApproverUserId])
  @@index([dueAt])
  @@map("approvals")
}

model ApprovalDelegation {
  id               String   @id @default(uuid())
  orgId            String
  delegatorUserId  String
  delegateUserId   String
  startDate        DateTime
  endDate          DateTime
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  delegator     User         @relation("ApprovalDelegationDelegator", fields: [delegatorUserId], references: [id], onDelete: Cascade)
  delegate      User         @relation("ApprovalDelegationDelegate", fields: [delegateUserId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, delegatorUserId])
  @@index([orgId, delegateUserId])
  @@map("approval_delegations")
}
