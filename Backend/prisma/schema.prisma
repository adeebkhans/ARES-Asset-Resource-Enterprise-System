// ARES (AssetFlow) — Prisma schema
// Phase 0 scope: tenancy/identity, master data, assets & lifecycle.
// Later phases extend this file with allocations, bookings, maintenance,
// audits, the generic approval engine, and the custom-object framework.
// See plan.md Section 4 for the full target data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// 4.1 Tenancy & Identity
// ---------------------------------------------------------------------------

enum IndustryTag {
  GENERIC
  SCHOOL
  HOSPITAL
  HOTEL
  FACTORY
  OTHER
}

model Organization {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  industryTag IndustryTag @default(GENERIC)
  settings    Json        @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users           User[]
  departments     Department[]
  assetCategories AssetCategory[]
  assets          Asset[]

  @@map("organizations")
}

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String     @id @default(uuid())
  orgId        String
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(EMPLOYEE)
  departmentId String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department?   @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  headOfDepartments Department[] @relation("DepartmentHead")

  @@unique([orgId, email])
  @@index([orgId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// 4.2 Master Data
// ---------------------------------------------------------------------------

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model Department {
  id                 String           @id @default(uuid())
  orgId              String
  name               String
  headUserId         String?
  parentDepartmentId String?
  status             DepartmentStatus @default(ACTIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  head         User?        @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: SetNull)
  parent       Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  children     Department[] @relation("DepartmentHierarchy")
  members      User[]       @relation("DepartmentMembers")

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

model AssetCategory {
  id                String   @id @default(uuid())
  orgId             String
  name              String
  description       String?
  customFieldSchema Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assets       Asset[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("asset_categories")
}

// ---------------------------------------------------------------------------
// 4.3 Assets & Lifecycle
// ---------------------------------------------------------------------------

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

model Asset {
  id                String      @id @default(uuid())
  orgId             String
  assetTag          String
  name              String
  categoryId        String
  serialNumber      String?
  acquisitionDate   DateTime?
  acquisitionCost   Decimal?    @db.Decimal(12, 2)
  condition         String?
  location          String?
  isShared          Boolean     @default(false)
  status            AssetStatus @default(AVAILABLE)
  customFieldValues Json        @default("{}")
  qrCodeUrl         String?
  photos            String[]    @default([])
  documents         String[]    @default([])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  organization  Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category      AssetCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  statusHistory AssetStatusHistory[]

  @@unique([orgId, assetTag])
  @@index([orgId])
  @@index([orgId, status])
  @@map("assets")
}

enum AssetStatusChangeSource {
  MANUAL
  ALLOCATION
  MAINTENANCE
  AUDIT
  TRANSFER
}

model AssetStatusHistory {
  id         String                  @id @default(uuid())
  assetId    String
  fromStatus AssetStatus?
  toStatus   AssetStatus
  changedBy  String?
  reason     String?
  source     AssetStatusChangeSource @default(MANUAL)
  timestamp  DateTime                @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_status_history")
}

// ---------------------------------------------------------------------------
// 4.8 Activity Logs
// ---------------------------------------------------------------------------

model ActivityLog {
  id           String   @id @default(uuid())
  orgId        String
  userId       String
  action       String
  entityType   String
  entityId     String
  metadata     Json     @default("{}")
  timestamp    DateTime @default(now())

  @@index([orgId])
  @@index([orgId, userId])
  @@index([orgId, entityType, entityId])
  @@map("activity_logs")
}
